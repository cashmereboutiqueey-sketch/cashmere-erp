# Environment Variables Template
# Copy this file to .env and fill in your values

# ─── Database ───────────────────────────────────────────────
POSTGRES_DB=cashmere_erp
POSTGRES_USER=cashmere
POSTGRES_PASSWORD=changeme123

# Full DATABASE_URL used by Django (auto-built from above in docker-compose)
# For bare-metal: uncomment and set directly
# DATABASE_URL=postgresql://cashmere:changeme123@localhost:5432/cashmere_erp

# ─── Django Backend ─────────────────────────────────────────
# IMPORTANT: Generate a real key with:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-this-to-a-random-50-character-string

DEBUG=False
ALLOWED_HOSTS=*

# Comma-separated list of origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
CORS_ALLOW_ALL_ORIGINS=False

# Comma-separated CSRF trusted origins (must match your domain)
CSRF_TRUSTED_ORIGINS=http://localhost:3000,https://yourdomain.com

# ─── Security (set to True in production with HTTPS) ────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False

# ─── Shopify Integration (Optional) ─────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_URL=

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Production overrides (update these for KVM/VPS) ────────
# SECRET_KEY=<generated-50-char-key>
# POSTGRES_PASSWORD=<strong-password>
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com
# CORS_ALLOWED_ORIGINS=https://yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# SECURE_SSL_REDIRECT=True
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
