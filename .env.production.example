# ─────────────────────────────────────────────────────────────────────────────
# Cashmere ERP — Production Environment (KVM2 / Hostinger VPS)
# ─────────────────────────────────────────────────────────────────────────────
# 1. Copy this file:   cp .env.production.example .env.production
# 2. Fill in every value (never commit .env.production to git)
# 3. Deploy:  docker compose -f docker-compose.prod.yml --env-file .env.production up -d --build

# ─── Database ───────────────────────────────────────────────────────────────
POSTGRES_DB=cashmere_erp
POSTGRES_USER=cashmere
# Use a strong password — at least 20 random characters
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# ─── Django ──────────────────────────────────────────────────────────────────
# Generate with: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=CHANGE_ME_DJANGO_SECRET_KEY

DEBUG=False

# Your KVM server's public IP and/or domain
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com,YOUR_SERVER_IP

# Must match your actual domain (HTTPS)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ─── Security (True = enforce HTTPS cookies) ─────────────────────────────────
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ─── Frontend ────────────────────────────────────────────────────────────────
# Public URL of the backend API — used by Next.js at build time
NEXT_PUBLIC_API_URL=https://yourdomain.com

# ─── Shopify (Optional) ──────────────────────────────────────────────────────
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=
SHOPIFY_STORE_URL=
